{
  "name": "batonkit-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Postgres-first local-first background worker framework with cloud backup failover.",
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/*",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:postgres": "node scripts/run-postgres-integration.mjs",
    "test:pack": "node scripts/pack-consumer-smoke.mjs",
    "drill:failover": "node scripts/failover-drill.mjs",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.1",
    "pg": "^8.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  }
}
