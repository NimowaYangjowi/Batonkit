{
  "name": "batonkit-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Postgres-first local-first background worker framework with cloud backup failover.",
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/* examples/railway-live-drill",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:postgres": "node scripts/run-postgres-integration.mjs",
    "test:pack": "node scripts/pack-consumer-smoke.mjs",
    "drill:failover": "node scripts/failover-drill.mjs",
    "drill:railway-live": "node examples/railway-live-drill/dist/drill.js run-local",
    "drill:railway-live:remote": "node examples/railway-live-drill/dist/drill.js run-remote",
    "drill:railway-live:enqueue": "node examples/railway-live-drill/dist/drill.js enqueue",
    "drill:railway-live:down": "node examples/railway-live-drill/dist/drill.js failover down",
    "drill:railway-live:up": "node examples/railway-live-drill/dist/drill.js failover up",
    "server:railway-live": "BATONKIT_PLATFORM=backup node examples/railway-live-drill/dist/server.js",
    "worker:railway-live:local": "BATONKIT_PLATFORM=local node examples/railway-live-drill/dist/worker.js",
    "worker:railway-live:backup": "BATONKIT_PLATFORM=backup node examples/railway-live-drill/dist/worker.js",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.1",
    "pg": "^8.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  }
}
