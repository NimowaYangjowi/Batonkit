{
  "name": "@batonkit/next",
  "version": "0.0.0",
  "description": "Next.js helpers for BatonKit.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
